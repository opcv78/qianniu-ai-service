{
  "name": "kao-gong-application",
  "version": "1.0.0",
  "private": true,
  "description": "图推动态解析 App - 公务员考试图形推理学习应用",
  "scripts": {
    "mobile": "pnpm --filter @kao-gong/mobile",
    "server": "pnpm --filter @kao-gong/server",
    "shared": "pnpm --filter @kao-gong/shared",
    "animation-core": "pnpm --filter @kao-gong/animation-core",
    "dev:mobile": "pnpm --filter @kao-gong/mobile start",
    "dev:server": "pnpm --filter @kao-gong/server dev",
    "build:packages": "pnpm --filter @kao-gong/shared build && pnpm --filter @kao-gong/animation-core build",
    "build:shared": "pnpm --filter @kao-gong/shared build",
    "build:animation-core": "pnpm --filter @kao-gong/animation-core build",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "postinstall": "pnpm build:packages"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
